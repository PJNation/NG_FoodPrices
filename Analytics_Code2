# ---- Packages ----
packages <- c("dplyr", "ggplot2", "lubridate", "scales")
to_install <- setdiff(packages, rownames(installed.packages()))
if (length(to_install)) install.packages(to_install)

# ggalign is preferred for arranging the main plot + insets
if (!requireNamespace("ggalign", quietly = TRUE)) {
  message("Package 'ggalign' not found. Falling back to 'patchwork' for layout.")
  if (!requireNamespace("patchwork", quietly = TRUE)) install.packages("patchwork")
}

library(dplyr)
library(ggplot2)
library(lubridate)
library(scales)

# ================================
# 1) Prepare daily averages
# ================================
# Expect columns:
#   - Date (daily), STATELABEL (state), price_Wm_1 (numeric price)
stopifnot(all(c("Date","STATELABEL","price_Wm_1") %in% names(raw_data_Wmze)))

wm_daily <- raw_data_Wmze %>%
  mutate(
    Date = as.Date(Date),                                  # ensure Date type
    STATELABEL = as.character(STATELABEL)
  ) %>%
  filter(!is.na(Date), !is.na(STATELABEL), !is.na(price_Wm_1)) %>%
  group_by(STATELABEL, Date) %>%
  summarise(avg_price = mean(price_Wm_1, na.rm = TRUE), .groups = "drop")

# Order states by their long-run mean price (highest at top, like the sample image)
state_order <- wm_daily %>%
  group_by(STATELABEL) %>%
  summarise(mu = mean(avg_price, na.rm = TRUE), .groups = "drop") %>%
  arrange(desc(mu)) %>%
  pull(STATELABEL)

wm_daily <- wm_daily %>%
  mutate(STATELABEL = factor(STATELABEL, levels = state_order))

# ================================
# 2) Build the main heatmap
# ================================
p_main <- ggplot(wm_daily, aes(x = Date, y = STATELABEL, fill = avg_price)) +
  geom_tile() +
  scale_fill_gradientn(
    colours = c("#fefdbf", "#fbdc6f", "#fdae61", "#f46d43", "#d73027"),
    name = "Avg price",
    label = label_number(big.mark = ","),
    guide = guide_colorbar(barheight = unit(80, "pt"))
  ) +
  labs(
    title   = "Daily White Maize Prices by State",
    subtitle= "Heatmap of daily state-level average prices",
    x       = NULL,
    y       = NULL
  ) +
  theme_minimal(base_size = 11) +
  theme(
    plot.title    = element_text(face = "bold", hjust = 0.5),
    plot.subtitle = element_text(hjust = 0.5),
    axis.text.y   = element_text(size = 8),
    panel.grid    = element_blank()
  )

# ================================
# 3) Marginal (inset) histograms
#    • Top: daily national mean price over time (as columns)
#    • Right: distribution of state means (over the period)
# ================================
# Top bars (one value per Date)
top_df <- wm_daily %>%
  group_by(Date) %>%
  summarise(national_mean = mean(avg_price, na.rm = TRUE), .groups = "drop")

p_top <- ggplot(top_df, aes(x = Date, y = national_mean)) +
  geom_col(width = 1, fill = "#ffd24d", color = NA) +
  labs(x = NULL, y = NULL) +
  theme_void() +
  theme(
    plot.margin = margin(b = 2),
    panel.grid  = element_blank()
  )

# Right bars (one value per State)
right_df <- wm_daily %>%
  group_by(STATELABEL) %>%
  summarise(state_mean = mean(avg_price, na.rm = TRUE), .groups = "drop") %>%
  mutate(STATELABEL = factor(STATELABEL, levels = state_order))

p_right <- ggplot(right_df, aes(x = state_mean, y = STATELABEL)) +
  geom_col(fill = "#ffd24d", color = NA) +
  labs(x = NULL, y = NULL) +
  theme_void() +
  theme(
    plot.margin = margin(l = 2),
    panel.grid  = element_blank()
  )

# ================================
# 4) Assemble like the reference (heatmap centered, bars on top and right)
# ================================
if (requireNamespace("ggalign", quietly = TRUE)) {
  library(ggalign)
  
  # ggalign’s layout: place top and right small panels around the main plot
  layout <- align() |>
    pack_top(height = 0.18) |>      # top inset height
    pack_right(width = 0.18)        # right inset width
  
  out <- layout |>
    insert(p_main) |>
    insert(p_top,   target = "top") |>
    insert(p_right, target = "right")
  
  print(out)
  
} else {
  # Fallback using patchwork
  library(patchwork)
  
  # relative sizes roughly mimic the sample image
  top_row   <- p_top + plot_spacer() + plot_layout(widths = c(1, 0.18))
  middle    <- p_main + p_right + plot_layout(widths = c(1, 0.18))
  final_plot <- top_row / middle + plot_layout(heights = c(0.18, 1))
  
  print(final_plot)
}




