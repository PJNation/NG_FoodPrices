# ============================================
# Correlation analysis: National Average (4 commodities)
# ============================================

library(dplyr)
library(tidyr)
library(lubridate)
library(ggplot2)
library(purrr)
library(broom)
library(scales)
# install.packages("ggrepel") # if not installed
library(ggrepel)

# ----------------------------
# 0) Helper: Nature-style theme
# ----------------------------
theme_nature <- function(base_size = 11){
  theme_minimal(base_size = base_size) +
    theme(
      plot.title.position = "plot",
      plot.title = element_text(face = "bold", size = base_size + 3, margin = margin(b = 6)),
      plot.subtitle = element_text(size = base_size + 1, margin = margin(b = 10)),
      plot.caption = element_text(size = base_size - 1, color = "grey30"),
      strip.text = element_text(face = "bold", size = base_size + 1),
      axis.title = element_text(size = base_size + 1),
      axis.text = element_text(size = base_size),
      panel.grid.minor = element_blank(),
      panel.grid.major.x = element_line(linewidth = 0.2),
      legend.position = "none"
    )
}

# ------------------------------------------------------------
# 1) Build monthly NATIONAL AVERAGES for both sources
#    - Level 2: already daily → monthly by zone; aggregate across zones
#    - FAO:     aggregate across zones to get national series
# ------------------------------------------------------------

# Ensure Date class
Level2_data_rtl <- Level2_data_rtl %>% mutate(Date = as.Date(Date))
fao_long           <- fao_long           %>% mutate(Date = as.Date(Date))

# Ensure commodity names are the canonical four for comparison
keep_comm <- c("White Maize", "Imported Rice", "Garri", "Yam")

# Level 2 national average per month & commodity
l2_nat <- Level2_data_rtl %>%
  mutate(Month = floor_date(Date, "month")) %>%
  group_by(Month, price_cate, Commodity) %>%
  summarise(
    L2_Price = mean(Price, na.rm = TRUE),
    n_l2 = dplyr::n(),
    .groups = "drop"
  ) %>%
  mutate(ZONELABEL1 = "National Average") %>%
  filter(Commodity %in% keep_comm)

# FAO national average per month & commodity (across zones)
fao_nat <- fao_long %>%
  mutate(Month = floor_date(Date, "month")) %>%
  group_by(Month, price_cate, Commodity) %>%
  summarise(
    FAO_Price = mean(Price, na.rm = TRUE),
    n_fao = dplyr::n(),
    .groups = "drop"
  ) %>%
  mutate(ZONELABEL1 = "National Average") %>%
  filter(Commodity %in% keep_comm)

# Window align (optional – match your paper window)
# Dec 2024 – Jun 2025 inclusive
time_min <- as.Date("2024-12-01")
time_max <- as.Date("2025-06-30")

l2_nat  <- l2_nat  %>% filter(Month >= time_min, Month <= time_max)
fao_nat <- fao_nat %>% filter(Month >= time_min, Month <= time_max)

# Pair up by Month + price_cate + Commodity
pair_nat <- inner_join(
  l2_nat  %>% dplyr::select(Month, price_cate, Commodity, L2_Price),
  fao_nat %>% dplyr::select(Month, price_cate, Commodity, FAO_Price),
  by = c("Month", "price_cate", "Commodity")
) %>%
  mutate(Commodity = factor(Commodity, levels = keep_comm)) %>%
  arrange(Commodity, Month)

# --------------------------------------------
# 2) Correlation stats per commodity (Pearson)
#    with 95% CI via Fisher z-transform
# --------------------------------------------
cor_per_comm <- pair_nat %>%
  group_by(Commodity) %>%
  summarise(
    n = sum(complete.cases(L2_Price, FAO_Price)),
    r = if (n >= 3) cor(L2_Price, FAO_Price, use = "complete.obs", method = "pearson") else NA_real_,
    p = if (n >= 3) cor.test(L2_Price, FAO_Price, method = "pearson")$p.value else NA_real_,
    .groups = "drop"
  ) %>%
  mutate(
    # Fisher z CI
    z = atanh(r),
    se_z = ifelse(!is.na(r) & n > 3, 1 / sqrt(n - 3), NA_real_),
    z_low = z - 1.96 * se_z,
    z_high = z + 1.96 * se_z,
    r_low = tanh(z_low),
    r_high = tanh(z_high),
    # Text label
    label = ifelse(
      is.na(r),
      paste0("n=", n),
      paste0(
        "r=", sprintf("%.2f", r),
        "  (95% CI ", sprintf("%.2f", r_low), "–", sprintf("%.2f", r_high), ")\n",
        "p=", ifelse(p < 0.001, "<0.001", sprintf("%.3f", p)),
        "  n=", n
      )
    )
  )

# --------------------------------------------
# 3) Faceted XY plot (FAO vs Level 2), one facet/commodity
#    - OLS fit with 95% CI
#    - Nature-grade styling
#    - Text annotation: r, 95% CI, p, n
# --------------------------------------------

# Axis limits per facet (optional). You can compute dynamically if needed.
# Here we share scales across facets to emphasize calibration across commodities
x_lim <- range(pair_nat$FAO_Price, na.rm = TRUE)
y_lim <- range(pair_nat$L2_Price, na.rm = TRUE)

p_xy <- ggplot(pair_nat, aes(x = FAO_Price, y = L2_Price)) +
  geom_abline(slope = 1, intercept = 0, linewidth = 0.6, linetype = "dashed", color = "grey40") +
  geom_smooth(method = "lm", se = TRUE, linewidth = 0.9, color = "#1f77b4", fill = alpha("#1f77b4", 0.18)) +
  geom_point(size = 2.4, alpha = 0.9, color = "black") +
  facet_wrap(~ Commodity, ncol = 2, scales = "fixed") +
  scale_x_continuous(limits = x_lim, labels = label_comma()) +
  scale_y_continuous(limits = y_lim, labels = label_comma()) +
  labs(
    title = "Source Agreement at National Level: FAO vs. Level 2 Monthly Prices",
    subtitle = "Faceted by commodity; dashed line is 1:1. OLS line with 95% confidence band.",
    x = "FAO Ground Truth (₦/kg)",
    y = "Level 2 (Daily → Monthly) (₦/kg)",
    caption = "Notes: Monthly national averages computed across zones; window: Dec 2024–Jun 2025."
  ) +
  theme_nature(base_size = 12)

# Add correlation annotations per facet
# Choose a corner inside each panel for placement (relative coords via Inf)
# We'll compute per-facet positions using scaled range.
ann_df <- pair_nat %>%
  group_by(Commodity) %>%
  summarise(
    x_pos = min(FAO_Price, na.rm = TRUE) + 0.05 * diff(range(FAO_Price, na.rm = TRUE)),
    y_pos = max(L2_Price, na.rm = TRUE) - 0.05 * diff(range(L2_Price, na.rm = TRUE)),
    .groups = "drop"
  ) %>%
  left_join(cor_per_comm %>% dplyr::select(Commodity, label), by = "Commodity")

p_xy <- p_xy +
  geom_label(
    data = ann_df,
    aes(x = x_pos, y = y_pos, label = label),
    size = 3.3, label.size = 0, label.r = unit(3, "pt"),
    fill = alpha("white", 0.7)
  )



# (Optional) Print correlation table
print(cor_per_comm)

# Save high-resolution figure
out_dir <- "fig_correlation_national"
if (!dir.exists(out_dir)) dir.create(out_dir, recursive = TRUE)
ggsave(
  filename = file.path(out_dir, "correlation_FAO_vs_Level2_National.png"),
  plot = p_xy, width = 8.5, height = 7.5, dpi = 600, bg = "white"
)



