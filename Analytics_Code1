ncol <- 5
nrow <- ceiling(n_panels / ncol)
idx_top_left <- 1
idx_bottom_left <- (nrow - 1) * ncol + 1
idx_bottom_left <- if (idx_bottom_left <= n_panels) idx_bottom_left else NA_integer_

# --- Legend embedded in TOP-LEFT panel ---
plots[[idx_top_left]] <- plots[[idx_top_left]] +
  labs(y = "Price (₦/kg)") +
  theme(
    axis.text.y  = element_text(size = 12),
    axis.title.y = element_text(size = 14, face = "bold"),
    # Turn legend ON and embed inside this panel
    legend.position = c(0.02, 0.98),                # top-left inside the panel
    legend.justification = c(0, 1),
    legend.direction = "horizontal",
    legend.background = element_rect(fill = "white", colour = "grey80"),
    legend.margin = margin(4, 6, 4, 6)
  ) +
  guides(color = guide_legend(override.aes = list(size = 3)))

# --- X axis labels + title only on BOTTOM-LEFT panel with added spacing ---
