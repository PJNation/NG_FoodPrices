# --- Helpers used by your functions ---
.na_omit <- function(z) {
  # keep finite numerics only
  z <- suppressWarnings(as.numeric(z))
  z[is.finite(z)]
}

.common_range <- function(x, y, trim = NULL) {
  xy <- c(.na_omit(x), .na_omit(y))
  if (length(xy) == 0) return(c(0, 1))
  if (is.null(trim)) {
    rng <- range(xy, na.rm = TRUE)
  } else {
    q <- quantile(xy, probs = trim, names = FALSE, type = 7, na.rm = TRUE)
    rng <- c(q[1], q[2])
  }
  # avoid zero-width ranges
  if (!is.finite(diff(rng)) || diff(rng) <= 0) rng <- rng + c(-0.5, 0.5)
  rng
}

# --- Your similarity functions (unchanged, now self-contained) ---
bhattacharyya_coef <- function(x, y, bins = 50, range = NULL) {
  x <- .na_omit(x); y <- .na_omit(y)
  if (length(x) == 0 || length(y) == 0) return(NA_real_)
  if (is.null(range)) range <- .common_range(x, y)
  hx <- hist(x, breaks = seq(range[1], range[2], length.out = bins + 1),
             plot = FALSE, include.lowest = TRUE, right = FALSE)
  hy <- hist(y, breaks = hx$breaks, plot = FALSE, include.lowest = TRUE, right = FALSE)
  px <- hx$counts / sum(hx$counts)
  py <- hy$counts / sum(hy$counts)
  sum(sqrt(px * py))
}

ovl_quantile_similarity <- function(x, y, probs = seq(0.01, 0.99, by = 0.01), trim_range = c(0.05, 0.95)) {
  x <- .na_omit(x); y <- .na_omit(y)
  if (length(x) == 0 || length(y) == 0) return(NA_real_)
  qx <- quantile(x, probs = probs, names = FALSE, type = 7)
  qy <- quantile(y, probs = probs, names = FALSE, type = 7)
  rng <- .common_range(x, y, trim = trim_range)
  denom <- diff(rng)
  if (!is.finite(denom) || denom <= 0) denom <- 1
  s <- 1 - mean(abs(qx - qy)) / denom
  max(0, min(1, s))
}

cosine_hist_similarity <- function(x, y, bins = 50, range = NULL) {
  x <- .na_omit(x); y <- .na_omit(y)
  if (length(x) == 0 || length(y) == 0) return(NA_real_)
  if (is.null(range)) range <- .common_range(x, y)
  hx <- hist(x, breaks = seq(range[1], range[2], length.out = bins + 1),
             plot = FALSE, include.lowest = TRUE, right = FALSE)
  hy <- hist(y, breaks = hx$breaks, plot = FALSE, include.lowest = TRUE, right = FALSE)
  vx <- hx$counts; vy <- hy$counts
  num <- sum(vx * vy)
  den <- sqrt(sum(vx * vx)) * sqrt(sum(vy * vy))
  if (den == 0) return(NA_real_)
  num / den
}

distribution_similarity <- function(x, y, bins = 50) {
  rng <- .common_range(x, y)
  data.frame(
    bhattacharyya = bhattacharyya_coef(x, y, bins = bins, range = rng),
    ovl_quantile  = ovl_quantile_similarity(x, y, trim_range = c(0.05, 0.95)),
    cosine_hist   = cosine_hist_similarity(x, y, bins = bins, range = rng)
  )
}

