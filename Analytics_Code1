theme_nature <- function(base_size = 11){
  theme_minimal(base_size = base_size) +
    theme(
      plot.title.position = "plot",
      plot.title = element_text(face = "bold", size = base_size + 3, margin = margin(b = 6)),
      plot.subtitle = element_text(size = base_size + 1, margin = margin(b = 10)),
      plot.caption = element_text(size = base_size - 1, color = "grey30"),
      strip.text = element_text(face = "bold", size = base_size + 1),
      axis.title = element_text(size = base_size + 1),
      axis.text = element_text(size = base_size),
      panel.grid.minor = element_blank(),
      panel.grid.major.x = element_line(linewidth = 0.2),
      legend.position = "none"
    )
}

# Ensure Date class
Level2_data_rtl <- Level2_data_rtl %>% mutate(Date = as.Date(Date))
fao_long        <- fao_long        %>% mutate(Date = as.Date(Date))

keep_comm <- c("White Maize", "Imported Rice", "Garri", "Yam")

# Level 2 national monthly
l2_nat <- Level2_data_rtl %>%
  mutate(Month = floor_date(Date, "month")) %>%
  group_by(Month, price_cate, Commodity) %>%
  summarise(L2_Price = mean(Price, na.rm = TRUE), n_l2 = dplyr::n(), .groups = "drop") %>%
  mutate(ZONELABEL1 = "National Average") %>%
  filter(Commodity %in% keep_comm)

# FAO national monthly
fao_nat <- fao_long %>%
  mutate(Month = floor_date(Date, "month")) %>%
  group_by(Month, price_cate, Commodity) %>%
  summarise(FAO_Price = mean(Price, na.rm = TRUE), n_fao = dplyr::n(), .groups = "drop") %>%
  mutate(ZONELABEL1 = "National Average") %>%
  filter(Commodity %in% keep_comm)

# Time window (Dec 2024–Jun 2025 inclusive)
time_min <- as.Date("2024-12-01")
time_max <- as.Date("2025-06-30")
l2_nat  <- l2_nat  %>% filter(Month >= time_min, Month <= time_max)
fao_nat <- fao_nat %>% filter(Month >= time_min, Month <= time_max)

# Pair up months
pair_nat <- inner_join(
  l2_nat  %>% select(Month, price_cate, Commodity, L2_Price),
  fao_nat %>% select(Month, price_cate, Commodity, FAO_Price),
  by = c("Month", "price_cate", "Commodity")
) %>%
  mutate(Commodity = factor(Commodity, levels = keep_comm)) %>%
  arrange(Commodity, Month)

# Correlation per commodity (Pearson + Fisher z CI)
cor_per_comm <- pair_nat %>%
  group_by(Commodity) %>%
  summarise(
    n = sum(complete.cases(L2_Price, FAO_Price)),
    r = if (n >= 3) cor(L2_Price, FAO_Price, use = "complete.obs", method = "pearson") else NA_real_,
    p = if (n >= 3) cor.test(L2_Price, FAO_Price, method = "pearson")$p.value else NA_real_,
    .groups = "drop"
  ) %>%
  mutate(
    z = atanh(r),
    se_z = ifelse(!is.na(r) & n > 3, 1 / sqrt(n - 3), NA_real_),
    z_low = z - 1.96 * se_z,
    z_high = z + 1.96 * se_z,
    r_low = tanh(z_low),
    r_high = tanh(z_high),
    label = ifelse(
      is.na(r),
      paste0("n=", n),
      paste0(
        "r=", sprintf("%.2f", r),
        "  (95% CI ", sprintf("%.2f", r_low), "–", sprintf("%.2f", r_high), ")\n",
        "p=", ifelse(p < 0.001, "<0.001", sprintf("%.3f", p)),
        "  n=", n
      )
    )
  )

# Annotation positions per facet (computed from each commodity’s own data range)
ann_df <- pair_nat %>%
  group_by(Commodity) %>%
  summarise(
    x_pos = min(FAO_Price, na.rm = TRUE) + 0.06 * diff(range(FAO_Price, na.rm = TRUE)),
    y_pos = max(L2_Price, na.rm = TRUE) - 0.06 * diff(range(L2_Price, na.rm = TRUE)),
    .groups = "drop"
  ) %>%
  left_join(cor_per_comm %>% select(Commodity, label), by = "Commodity")

# Faceted XY with FREE scales (each commodity has its own axes & ranges)
p_xy <- ggplot(pair_nat, aes(x = FAO_Price, y = L2_Price)) +
  geom_abline(slope = 1, intercept = 0, linewidth = 0.6, linetype = "dashed", color = "grey40") +
  geom_smooth(method = "lm", se = TRUE, linewidth = 0.9, color = "#1f77b4", fill = alpha("#1f77b4", 0.18)) +
  geom_point(size = 2.4, alpha = 0.9, color = "black") +
  facet_wrap(~ Commodity, ncol = 2, scales = "free") +   # <-- key change
  scale_x_continuous(labels = label_comma()) +
  scale_y_continuous(labels = label_comma()) +
  labs(
    title = "Source Agreement at National Level: FAO vs. Level 2 Monthly Prices",
    subtitle = "Faceted by commodity; dashed line is 1:1. OLS line with 95% confidence band.",
    x = "FAO Ground Truth (₦/kg)",
    y = "Level 2 (Daily → Monthly) (₦/kg)",
    caption = "Notes: Monthly national averages computed across zones; window: Dec 2024–Jun 2025."
  ) +
  theme_nature(base_size = 12)

# Add correlation labels (per facet)
p_xy <- p_xy +
  geom_label(
    data = ann_df,
    aes(x = x_pos, y = y_pos, label = label),
    size = 3.3, label.size = 0, label.r = unit(3, "pt"),
    fill = alpha("white", 0.7)
  )

# Save high-res figure
