# Base plot builder for a single commodity (legend OFF by default)
make_panel <- function(df, title_txt) {
  ggplot(df, aes(x = Date, y = Price_kg, color = Source)) +
    geom_smooth(method = "loess", se = TRUE, linetype = "solid", size = 1) +
    coord_cartesian(ylim = c(0, 4000)) +
    scale_x_date(breaks = "1 month", labels = date_format("%b"), minor_breaks = "1 week") +
    scale_color_manual(values = c("Crowdsourced" = "orange", "Enumerators" = "chartreuse4")) +
    labs(x = NULL, y = NULL, title = title_txt, color = NULL) +
    #theme_bw() +  #removing this to give grey background
    theme(
      text = element_text(size = 12, color = "black"),
      plot.title = element_text(size = 14, hjust = 0.5),  # to Bolded commodity name, insert >>face = "bold"
      panel.grid.minor = element_blank(),
      panel.border = element_rect(colour = "grey", fill = NA, size = 1.2),
      # Ticks ON for all panels
      axis.ticks.x = element_line(),
      axis.ticks.y = element_line(),
      # Hide tick LABELS by default (we'll enable selectively)
      axis.text.x = element_blank(),
      axis.text.y = element_blank(),
      # No legend by default (we'll enable only on top-left)
      legend.position = "none"
    )
}

# Build a panel for each commodity
split_list <- split(all_data, all_data$Commodity)
plots <- lapply(names(split_list), function(comm) make_panel(split_list[[comm]], comm))

# Determine positions in a 5-column layout
