      subtitle = "Crowdsourced vs FAO FPMA Retail Prices",
      x = NULL, y = "Price (₦/kg)",
      caption = "Notes: Points are monthly means; error bars are 95% CI (zero-length if only one observation in a month)."
    ) +
    theme_nature(base_size = 12)
  
  # ---- Facet-specific axes:
  # Y labels ONLY on White Maize; others show ticks/line but labels suppressed
  p <- p + ggh4x::facetted_pos_scales(
    y = list(
      Commodity == "White Maize" ~ ggplot2::scale_y_continuous(labels = scales::label_number(big.mark = ",")),
      TRUE                       ~ ggplot2::scale_y_continuous(labels = NULL)
    ),
    # X labels ONLY on Garri; labels are month abbreviations (no year).
    x = list(
      Commodity == "Garri" ~ ggplot2::scale_x_date(
        breaks = monthly_breaks(df_zone$Month),
        date_labels = "%b",
        expand = ggplot2::expansion(mult = c(0.01, 0.02))
      ),
      TRUE ~ ggplot2::scale_x_date(
        breaks = monthly_breaks(df_zone$Month),
        labels = NULL,
        expand = ggplot2::expansion(mult = c(0.01, 0.02))
      )
    )
  )
  
  p
}

