# --- Helper to compute histogram-overlap for one commodity --------------------
compute_hist_overlap <- function(df,
                                 bins_default = 30,
                                 auto_bins = TRUE,
                                 min_bins = 10,
                                 max_bins = 60) {
  x_all <- df$Price_kg
  if (length(x_all) < 2) {
    return(tibble(
      overlap_pct = NA_real_, bins_used = NA_integer_,
      n_crowd = sum(df$Source == "Crowdsourced"),
      n_validators = sum(df$Source == "Enumerators"),
      note = "too few observations"
    ))
  }
  
  # Choose number of bins (Freedman–Diaconis, clamped)
  if (auto_bins) {
    bins_fd <- tryCatch(nclass.FD(x_all), error = function(e) NA_integer_)
    bins_used <- if (is.finite(bins_fd)) {
      max(min_bins, min(max_bins, bins_fd))
    } else bins_default
  } else {
    bins_used <- bins_default
  }
  
  rng <- range(x_all, na.rm = TRUE)
  if (!is.finite(rng[1]) || !is.finite(rng[2]) || rng[1] == rng[2]) {
    return(tibble(
      overlap_pct = NA_real_, bins_used = bins_used,
      n_crowd = sum(df$Source == "Crowdsourced"),
      n_validators = sum(df$Source == "Enumerators"),
      note = "zero price range"
    ))
  }
  
  # Shared equal-width breaks across both sources
  breaks <- seq(rng[1], rng[2], length.out = bins_used + 1)
  
  # Histogram counts per source on the shared breaks
  counts <- df %>%
    group_by(Source) %>%
    summarise(
      n = n(),
      counts = list(hist(Price_kg, breaks = breaks, plot = FALSE,
                         include.lowest = TRUE, right = FALSE)$counts),
      .groups = "drop"
    )
  
  if (nrow(counts) < 2) {
    return(tibble(
      overlap_pct = NA_real_, bins_used = bins_used,
      n_crowd = sum(df$Source == "Crowdsourced"),
      n_validators = sum(df$Source == "Enumerators"),
      note = "one source missing"
    ))
  }
  
  p_crowd <- counts$counts[[which(counts$Source == "Crowdsourced")]]
  p_val   <- counts$counts[[which(counts$Source == "Enumerators")]]
  
  if (sum(p_crowd) == 0 || sum(p_val) == 0) {
    return(tibble(
      overlap_pct = NA_real_, bins_used = bins_used,
      n_crowd = counts$n[counts$Source == "Crowdsourced"],
      n_validators = counts$n[counts$Source == "Enumerators"],
      note = "empty histogram"
    ))
  }
  
  # Convert to per-bin probabilities (sum to 1 per source)
  p_crowd <- p_crowd / sum(p_crowd)
  p_val   <- p_val   / sum(p_val)
  
  overlap <- sum(pmin(p_crowd, p_val)) * 100
  
  tibble(
    overlap_pct = round(overlap, 1),
    bins_used   = bins_used,
    n_crowd     = counts$n[counts$Source == "Crowdsourced"],
    n_validators= counts$n[counts$Source == "Enumerators"],
    note        = NA_character_
  )
}

