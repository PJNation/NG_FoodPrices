##Descriptive stats for prices across commodities
library(dplyr)
library(gt)
library(moments)   # for skewness() and kurtosis()

commodity_stats <- price_clean %>%
  group_by(commodity) %>%
  summarise(
    n            = sum(!is.na(price)),
    mean_price   = mean(price, na.rm = TRUE),
    median_price = median(price, na.rm = TRUE),
    sd_price     = sd(price, na.rm = TRUE),
    var_price    = var(price, na.rm = TRUE),
    min_price    = min(price, na.rm = TRUE),
    max_price    = max(price, na.rm = TRUE),
    range_price  = max(price, na.rm = TRUE) - min(price, na.rm = TRUE),
    
    # Quartiles
    Q1_price     = quantile(price, 0.25, na.rm = TRUE),
    Q3_price     = quantile(price, 0.75, na.rm = TRUE),
    IQR_price    = IQR(price, na.rm = TRUE),
    
    # Coefficient of Variation
    CV_price     = sd(price, na.rm = TRUE) / mean(price, na.rm = TRUE),
    
    # Skewness & Kurtosis
    skewness     = skewness(price, na.rm = TRUE),
    kurtosis     = kurtosis(price, na.rm = TRUE)
  ) %>%
  arrange(commodity)


# ------------------------
# Format as a GT table
# ------------------------

commodity_table <- commodity_stats %>%
  gt() %>%
  tab_header(
    title = "Descriptive Statistics of Commodity Prices",
    subtitle = "Based on Cleaned Intraday Submissions (Outliers Removed)"
  ) %>%
  fmt_number(
    columns = where(is.numeric),
    decimals = 2
  ) %>%
