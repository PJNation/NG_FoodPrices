# Helper to compute CI components safely (returns zero-length CI if n_obs <= 1)
summarise_monthly <- function(df, group_vars) {
  df %>%
    mutate(Month = lubridate::floor_date(Date, "month")) %>%
    group_by(across(all_of(group_vars))) %>%
    summarise(
      Price_mean = mean(Price, na.rm = TRUE),
      n_obs = dplyr::n(),
      sd    = ifelse(n_obs > 1, stats::sd(Price, na.rm = TRUE), 0),
      se    = ifelse(n_obs > 1, sd / sqrt(n_obs), 0),
      ci95  = 1.96 * se,
      .groups = "drop"
    ) %>%
    transmute(
      Month, ZONELABEL1 = if ("ZONELABEL1" %in% names(.)) ZONELABEL1 else NA_character_,
      price_cate = if ("price_cate" %in% names(.)) price_cate else NA_character_,
      Commodity,
      Price = Price_mean,
      n_obs, sd, se, ci95,
      ymin = pmax(Price_mean - ci95, 0),
      ymax = Price_mean + ci95
    )
}

