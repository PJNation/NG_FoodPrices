library(rlang)


# 1) Common columns shared across all datasets (includes price_cate as given)
common_vars <- c(
  "FID","date","ZONECODE1","geopol_zon","STATECODE1",
  "ZONELABEL1","STATELABEL","lga","lgalabel","sector",
  "VC_ID2","Staff_Vali","market_typ","price_cate",
  "market_tim","gps_latitu","gps_longit","Date"
)

# 2) List all data frames named like raw_data_<XYZ>
df_names <- ls(pattern = "^raw_data_")
df_names <- df_names[!df_names %in% c("raw_data_all", "raw_data_tidy", "raw_data_Wbean")]

# 3) Helper to process each dataset
process_one <- function(nm) {
  df <- get(nm, envir = .GlobalEnv)
  
  # Q column (expect exactly one per dataset)
  q_cols <- grep("^Q_", names(df), value = TRUE)
  if (length(q_cols) == 0) stop(sprintf("No Q_ column found in %s", nm))
  if (length(q_cols) > 1)  message(sprintf("Multiple Q_ columns in %s; using %s", nm, q_cols[1]))
  q_col <- q_cols[1]
  
  # Numeric price column(s): starts with price_/Price_ but NOT price_cate; keep numeric only
  p_all <- grep("^(Price_|price_)", names(df), value = TRUE)
  p_numeric_candidates <- setdiff(p_all, c("price_cate","Price_cate"))
  # keep only numeric-typed candidates
  if (length(p_numeric_candidates)) {
    p_numeric_candidates <- p_numeric_candidates[
      vapply(df[p_numeric_candidates], is.numeric, logical(1))
    ]
  }
  if (length(p_numeric_candidates) == 0)
    stop(sprintf("No numeric price_* column found in %s (excluding price_cate)", nm))
  if (length(p_numeric_candidates) > 1)
    message(sprintf("Multiple numeric price_* in %s; using %s", nm, p_numeric_candidates[1]))
  p_num <- p_numeric_candidates[1]
  
  commodity <- sub("^raw_data_", "", nm)
  
  df %>%
    # Keep common vars (includes price_cate) + Q + numeric price_*
    dplyr::select(any_of(common_vars), all_of(q_col), all_of(p_num)) %>%
    # Rename to generic names
    rename(Q = !!q_col, Price = !!p_num) %>%
    # Add Commodity from the data frame name
    mutate(Commodity = commodity) %>%
    relocate(Commodity, .after = last_col())
}

# 4) Apply to all and combine
merged_commodities <- map_dfr(df_names, process_one)


Level2_data<-merged_commodities[merged_commodities$Price<7000 & merged_commodities$Price>100,]



write.csv(Level2_data, "Leve2_dataset_NFPT.csv", row.names = FALSE, na = "")

