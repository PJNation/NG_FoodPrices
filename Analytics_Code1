      axis.title.x = element_text(size = 14, face = "bold",
                                  margin = margin(t = 10))  # add spacing between ticks and title
    )
}

# Assemble (no global legend collection; legend is embedded in top-left plot)
final_plot <- wrap_plots(plots, ncol = ncol)

final_plot


