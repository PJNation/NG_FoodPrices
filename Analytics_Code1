# ----------------------------
# 4) Helper to compute stats on paired vectors
# ----------------------------
compute_stats <- function(x, y) {
  ok <- complete.cases(x, y)
  x <- x[ok]; y <- y[ok]
  n <- length(x)
  
  # Defaults for small n
  res <- list(n_pairs = n, r = NA_real_, r2 = NA_real_,
              cor_p = NA_real_, t_stat = NA_real_, df = NA_real_, t_p = NA_real_)
  
  if (n >= 2) {
    # Paired t-test
    tt <- try(suppressWarnings(t.test(x, y, paired = TRUE)), silent = TRUE)
    if (!inherits(tt, "try-error")) {
      res$t_stat <- unname(tt$statistic)
      res$df     <- unname(tt$parameter)
      res$t_p    <- unname(tt$p.value)
    }
  }
  if (n >= 3) {
    # Pearson correlation (p from cor.test)
    ct <- try(suppressWarnings(cor.test(x, y, method = "pearson")), silent = TRUE)
    if (!inherits(ct, "try-error")) {
      res$r    <- unname(ct$estimate)
      res$r2   <- res$r^2
      res$cor_p <- unname(ct$p.value)
    }
  }
  res
}

