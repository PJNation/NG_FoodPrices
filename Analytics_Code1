# Make sure date is Date class
price_data <- raw_data %>%
  mutate(date = as.Date(date,format = "%m/%d/%Y"))

# ---------------------------
# 1. Rename & pivot to long
# ---------------------------


price_data <- price_data %>%
  rename(
    price_Ym_1  = price_Ym_1,   # Yellow maize
    price_Wm_1  = price_Wm_1,   # White maize
    price_so_1  = price_so_1,   # Sorghum
    price_impo_1 = price_impo_1,# Imported rice
    price_lo_1  = price_lo_1,   # Local rice
    price_br_1  = price_br_1,   # Brown beans
    price_Wh_1  = price_Wh_1,   # White beans
    price_ga_1  = price_ga_1,   # Garri
    price_yam_  = price_yam_,   # Yam
    price_so_2  = price_so_2    # Soybean
  )

# Map wide column names to human-readable commodity names
commodity_map <- c(
  price_Ym_1  = "Yellow Maize",
  price_Wm_1  = "White Maize",
  price_so_1  = "Sorghum",
  price_impo_1 = "Imported Rice",
  price_lo_1  = "Local Rice",
  price_br_1  = "Brown Beans",
  price_Wh_1  = "White Beans",
  price_ga_1  = "Garri",
  price_yam_  = "Yam",
  price_so_2  = "Soybean"
)

# Pivot to long: keep all other columns (including date, Staff_Vali)
price_long <- price_data %>%
  pivot_longer(
    cols = all_of(names(commodity_map)),
    names_to = "commodity_code",
    values_to = "price"
  ) %>%
  mutate(
    commodity = commodity_map[commodity_code]
  )


#Remove spurious values

price_long<-subset(price_long, price>=100 & price<=6000) #Comment this to return all dataset without the mask

# ---------------------------
# 2. Daily SD for each commodity
# ---------------------------
price_long <- price_long %>%
  group_by(date, commodity) %>%
  mutate(
    daily_mean = mean(price, na.rm = TRUE),
    daily_sd   = sd(price, na.rm = TRUE)
  ) %>%
  ungroup()

# ---------------------------
# 3. Flag outliers (> 2.5 SD from daily mean)
# ---------------------------
# Handle cases where daily_sd is 0 or NA (no outliers in that case)
price_long <- price_long %>%
  mutate(
    outlier_flag = case_when(
      is.na(price) | is.na(daily_sd) | daily_sd == 0 ~ "non-outlier",
      abs(price) >  daily_mean + (2.5 * daily_sd)      ~ "outlier",
      abs(price) < daily_mean - (2.5 * daily_sd)      ~ "outlier",
      TRUE                                          ~ "non-outlier"
    )
  )

# ---------------------------
# 5. Create dataset excluding outliers
# ---------------------------
price_clean <- price_long %>%
  filter(outlier_flag == "non-outlier")



# ---------------------------
# 4. Tabulate & export outlier counts per day
# ---------------------------
outlier_counts <- price_long %>%
  filter(outlier_flag == "outlier") %>%
  count(date, commodity, name = "n_outliers") %>%
  arrange(date, commodity)

# Export to count of outliers per day to CSV
write.csv(outlier_counts, "outlier_counts_by_day_alt.csv", row.names = FALSE)


