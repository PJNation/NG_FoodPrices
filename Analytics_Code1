# Helper: % overlap between histograms (shared breaks) for one commodity
compute_overlap <- function(df, bins_used = bins) {
  x <- df$Price_kg
  if (length(x) < 2 || length(unique(x)) < 2) {
    return(tibble(overlap_pct = NA_real_, bins_used = bins_used))
  }
  rng <- range(x, na.rm = TRUE)
  if (!is.finite(rng[1]) || !is.finite(rng[2]) || rng[1] == rng[2]) {
    return(tibble(overlap_pct = NA_real_, bins_used = bins_used))
  }
  breaks <- seq(rng[1], rng[2], length.out = bins_used + 1)
  
  counts <- df %>%
    group_by(Source) %>%
    summarise(
      n = n(),
      counts = list(hist(Price_kg, breaks = breaks, plot = FALSE,
                         include.lowest = TRUE, right = FALSE)$counts),
      .groups = "drop"
    )
  
  if (!all(c("Crowdsourced","Enumerators") %in% counts$Source)) {
    return(tibble(overlap_pct = NA_real_, bins_used = bins_used))
  }
  
  p1 <- counts$counts[[which(counts$Source == "Crowdsourced")]]
  p2 <- counts$counts[[which(counts$Source == "Enumerators")]]
  if (sum(p1) == 0 || sum(p2) == 0) {
    return(tibble(overlap_pct = NA_real_, bins_used = bins_used))
  }
  
  # Normalize to probabilities, then sum of per-bin minima
  p1 <- p1 / sum(p1); p2 <- p2 / sum(p2)
  overlap <- sum(pmin(p1, p2)) * 100
  
  tibble(overlap_pct = round(overlap, 1), bins_used = bins_used)
}

