# Helper: compute cross-correlation matrix (0 on Y-axis, 1 on X-axis)
make_cross_corr_matrix <- function(agg_data, time_var) {
  
  wide <- agg_data %>%
    mutate(
      Staff_Vali = as.character(Staff_Vali),
      new_name = paste(commodity, Staff_Vali, sep = "_")
    ) %>%
    select(all_of(time_var), new_name, mean_price) %>%
    pivot_wider(names_from = new_name, values_from = mean_price)
  
  mat0 <- wide %>% select(ends_with("_0")) %>% as.matrix()
  mat1 <- wide %>% select(ends_with("_1")) %>% as.matrix()
  
  cross_cor <- matrix(NA, ncol(mat0), ncol(mat1))
  rownames(cross_cor) <- colnames(mat0)
  colnames(cross_cor) <- colnames(mat1)
  
  for (i in seq_len(ncol(mat0))) {
    for (j in seq_len(ncol(mat1))) {
      cross_cor[i, j] <- cor(mat0[, i], mat1[, j], use = "pairwise.complete.obs")
    }
  }
  return(cross_cor)
}

# Convert matrix to long format with diagonal ID
corr_to_long <- function(cmat) {
  as.data.frame(cmat) %>%
    mutate(Y = rownames(cmat)) %>%
    pivot_longer(
      cols = -Y,
      names_to = "X",
      values_to = "corr"
    ) %>%
    mutate(
      commodity_Y = str_remove(Y, "_0$"),
      commodity_X = str_remove(X, "_1$"),
      is_diagonal = commodity_Y == commodity_X
    )
}

# Heatmap with:
#   - bold diagonal text
#   - thick borders around diagonal tiles
plot_heatmap <- function(df_long, title_text) {
  
  ggplot(df_long, aes(x = commodity_X, y = commodity_Y, fill = corr)) +
    
    # Base tiles
    geom_tile(color = "white") +
    
    # THICK BORDER around diagonal tile
    geom_tile(
      data = df_long %>% filter(is_diagonal),
      color = "darkgreen",
      lwd = 1.2,        # thickness of the border
      fill = NA          # keep original fill below
    ) +
    
    # TEXT (bold on diagonal)
    geom_text(
      aes(
        label = sprintf("%.2f", corr),
        fontface = ifelse(is_diagonal, "bold", "plain")
      ),
      size = 3.8,
      color = "black"
    ) +
    
    scale_fill_gradient2(
      low = "orange",
      high = "green",
      mid = "lightblue",
      midpoint = 0,
      limit = c(-1, 1),
      name = "Correlation"
    ) +
    
    theme_minimal() +
    theme(
      axis.text.x = element_text(angle = 60, hjust = 1, size = 12, face="italic"),
      axis.text.y = element_text(size = 12, face = "italic"),
      plot.title  = element_text(size = 12, face = "bold", hjust = 0.5)
    ) +
    
    labs(
      x = "Commodity Prices from Enumerators",
      y = "Commodity Prices from Volunteer Crowd",
      title = title_text, size = 14, face="bold"
    )
}

