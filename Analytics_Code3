# 8. CORRELATION HEATMAPS WITH LABELS
#     - Staff_Vali = 0 on Y-axis
#     - Staff_Vali = 1 on X-axis
# ============================

library(ggplot2)
library(tidyr)
library(dplyr)

# Helper: compute correlation matrix with STAFF 0 variables (rows) and STAFF 1 variables (columns)
make_cross_corr_matrix <- function(agg_data, time_var) {
  
  wide <- agg_data %>%
    mutate(
      Staff_Vali = as.character(Staff_Vali),
      new_name = paste(commodity, Staff_Vali, sep = "_")
    ) %>%
    select(all_of(time_var), new_name, mean_price) %>%
    pivot_wider(
      names_from = new_name,
      values_from = mean_price
    )
  
  # Split into 0 and 1 matrices
  mat0 <- wide %>% select(ends_with("_0")) %>% as.matrix()
  mat1 <- wide %>% select(ends_with("_1")) %>% as.matrix()
  
  cross_cor <- matrix(NA, ncol(mat0), ncol(mat1))
  rownames(cross_cor) <- colnames(mat0)
  colnames(cross_cor) <- colnames(mat1)
  
  for (i in seq_len(ncol(mat0))) {
    for (j in seq_len(ncol(mat1))) {
      cross_cor[i, j] <- cor(mat0[, i], mat1[, j], use = "pairwise.complete.obs")
    }
  }
  return(cross_cor)
}

# Convert matrix to long format
corr_to_long <- function(cmat) {
  as.data.frame(cmat) %>%
    mutate(Y = rownames(cmat)) %>%
    pivot_longer(
      cols = -Y,
      names_to = "X",
      values_to = "corr"
    )
}

# Heatmap with labels
plot_heatmap <- function(df_long, title_text) {
  ggplot(df_long, aes(x = X, y = Y, fill = corr)) +
    geom_tile(color = "white") +
    geom_text(aes(label = sprintf("%.2f", corr)), size = 3.5, color = "black") +
    scale_fill_gradient2(
      low = "orange",
      high = "green",
      mid = "lightblue",
      midpoint = 0,
      limit = c(-1, 1),
      name = "Correlation"
    ) +
    theme_minimal() +
    theme(
      axis.text.x = element_text(angle = 60, hjust = 1, size = 10),
      axis.text.y = element_text(size = 10),
      plot.title = element_text(size = 12, face = "bold", hjust = 0.5)
    ) +
    labs(
      x = "Commodity Prices (Staff_Vali = 1)",
      y = "Commodity Prices (Staff_Vali = 0)",
      title = title_text
    )
}

