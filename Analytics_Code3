# Helper: function to build a correlation matrix where columns are
# mean prices by (commodity, Staff_Vali), and rows are time periods

make_corr_matrix <- function(agg_data, time_var) {
  # agg_data has: Staff_Vali, commodity, time_var, mean_price
  wide_data <- agg_data %>%
    mutate(
      Staff_Vali = as.character(Staff_Vali),
      col_name   = paste(commodity, Staff_Vali, sep = "_")
    ) %>%
    select(all_of(time_var), col_name, mean_price) %>%
    pivot_wider(
      names_from  = col_name,
      values_from = mean_price
    )
  
  # Remove the time column before correlation
  mat <- wide_data %>%
    select(-all_of(time_var)) %>%
    as.matrix()
  
  cor(mat, use = "pairwise.complete.obs")
}

